# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/construction_suite

# ─── JWT ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── File Storage (MinIO / AWS S3) ────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3
LOCAL_UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=construction-suite
AWS_REGION=af-south-1

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Construction Management Suite
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
